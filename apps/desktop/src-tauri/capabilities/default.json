{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:event:default",
    "core:window:default",
    "core:app:default",
    "allow-start-agent",
    "allow-start-agent-from-task",
    "allow-stop-agent",
    "allow-ai-compile-workflow",
    "allow-ai-refine-workflow",
    "allow-get-ai-api-key",
    "allow-set-ai-api-key",
    "allow-copy-to-clipboard",
    "allow-check-permissions",
    "allow-open-system-settings-pane",
    "allow-restart-recorder-service",
    "allow-system-status",
    "allow-recorder-status",
    "allow-start-recording",
    "allow-stop-recording",
    "allow-storage-smoke-test",
    "allow-list-sessions",
    "allow-list-session-events",
    "allow-load-keyframe-bytes",
    "allow-list-workflow-runs",
    "allow-list-workflow-run-logs",
    "allow-get-retention-policy",
    "allow-update-retention-policy",
    "allow-update-session-description",
    "allow-run-retention-cleanup-now",
    "allow-compile-workflow-preview",
    "allow-execute-session-workflow",
    "allow-execute-workflow-json",
    "allow-approve-workflow-run",
    "allow-reject-workflow-run"
  ]
}

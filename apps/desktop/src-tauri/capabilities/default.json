{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:event:default",
    "core:window:default",
    "core:app:default",
    "allow-system-status",
    "allow-recorder-status",
    "allow-start-recording",
    "allow-stop-recording",
    "allow-storage-smoke-test"
  ]
}

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clone a Process",
  "version": "0.1.0",
  "identifier": "com.cloneaprocess.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Clone a Process",
        "width": 1440,
        "height": 960,
        "resizable": true
      }
    ],
    "security": {
      "capabilities": ["main-capability"]
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}


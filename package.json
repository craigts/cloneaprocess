{
  "name": "cloneaprocess",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/desktop",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @cloneaprocess/desktop",
